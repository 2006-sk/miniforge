MAKERS_MODELS_KEY=            # EdgeOne Makers model gateway key
NEBIUS_API_KEY=               # Nebius Token Factory (fallback + vision)
SERPAPI_API_KEY=              # SerpApi (serpapi.com) web search
SERPER_API_KEY=               # alias accepted (same key)
TEXT_MODEL=claude-sonnet-4-6  # gateway-first; Nebius maps Claude IDs → NEBIUS_TEXT_MODEL
NEBIUS_TEXT_MODEL=meta-llama/Llama-3.3-70B-Instruct
# Nebius vision (Qwen2.5-VL-72B is a strong label/OCR model on Token Factory)
VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
PORT=3000
